# title = ""
# macos-titlebar-style = transparent
# macos-window-buttons = hidden
# window-subtitle = false
# window-decoration = auto
confirm-close-surface = false
custom-shader = shaders/cursor_tail.glsl
custom-shader = shaders/ripple_cursor.glsl
mouse-hide-while-typing = true
shell-integration-features = no-cursor
window-padding-x = 6
window-padding-y = 6
window-padding-balance = true
cursor-style = block
cursor-style-blink = false
font-size = 22
font-family = ZedMono Nerd Font Mono
font-style = Bold
palette = 0=#324a4d
palette = 1=#e66533
palette = 2=#49e9a6
palette = 3=#e4b781
palette = 4=#49ace9
palette = 5=#df769b
palette = 6=#49d6e9
palette = 7=#b2cacd
palette = 8=#47686c
palette = 9=#e97749
palette = 10=#60ebb1
palette = 11=#e69533
palette = 12=#60b6eb
palette = 13=#e798b3
palette = 14=#60dbeb
palette = 15=#c1d4d7
background = #031417
foreground = #b2cacd
cursor-color = #b2cacd
cursor-text = #031417
selection-background = #0d2a2f
selection-foreground = #b2cacd
palette = 16=#e58e5a
palette = 17=#cc9880
