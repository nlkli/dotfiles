#!/usr/bin/env bash

# Sync personal configuration files between the local system and repository.
#
# Usage:
#   ./sync in   # Apply repository configs to the system
#   ./sync out  # Save system configs to repository

set -e

# Repository config directory
CONFIG_DIR="./config"

# Use XDG config path if available, otherwise fallback to ~/.config
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"

# Directory configs
NVIM_DIR="$CONFIG_HOME/nvim"
ALACRITTY_DIR="$CONFIG_HOME/alacritty"
GHOSTTY_DIR="$CONFIG_HOME/ghostty"
YAZI_DIR="$CONFIG_HOME/yazi"

# Repository directory configs
NVIM_REPO="$CONFIG_DIR/nvim"
ALACRITTY_REPO="$CONFIG_DIR/alacritty"
GHOSTTY_REPO="$CONFIG_DIR/ghostty"
YAZI_REPO="$CONFIG_DIR/yazi"

# File configs
VIMRC_FILE="$HOME/.vim/.vimrc"
GITCONFIG_FILE="$HOME/.gitconfig"
ZSHRC_FILE="$HOME/.zshrc"
BASHRC_FILE="$HOME/.bashrc"
TMUX_FILE="$HOME/.tmux.conf"

# Repository file configs
VIMRC_REPO="$CONFIG_DIR/.vimrc"
GITCONFIG_REPO="$CONFIG_DIR/.gitconfig"
ZSHRC_REPO="$CONFIG_DIR/.zshrc"
BASHRC_REPO="$CONFIG_DIR/.bashrc"
TMUX_REPO="$CONFIG_DIR/.tmux.conf"

MODE="${1:-}"

if [[ "$MODE" != "in" && "$MODE" != "out" ]]; then
    echo "Usage: $0 {in|out}"
    exit 1
fi

# Prevent accidental overwrite of repository configs
if [[ "$MODE" == "out" ]]; then
    read -r -p "Sync configs from system to repository? [y/N] " answer
    if [[ "$answer" != "y" && "$answer" != "Y" ]]; then
        echo "Cancelled"
        exit 0
    fi
fi

log() {
    printf "%-20s %s\n" "$1" "$2"
}

# Sync a single file or directory
_sync() {
    local src="$1"
    local dst="$2"
    local name

    name=$(basename "$src")

    if [[ ! -e "$src" ]]; then
        log "$name" "[missing]"
        return
    fi

    # Create destination parent directory if needed
    if [[ -d "$src" ]]; then
        mkdir -p "$dst"
    else
        mkdir -p "$(dirname "$dst")"
    fi

    if diff -rq "$src" "$dst" >/dev/null 2>&1; then
        log "$name" "[unchanged]"
        return
    fi

    if [[ -d "$src" ]]; then
        cp -R "$src/." "$dst"
    else
        cp -f "$src" "$dst"
    fi

    log "$name" "[updated]"
}

# Sync direction wrapper
sync() {
    local system="$1"
    local repo="$2"

    if [[ "$MODE" == "in" ]]; then
        _sync "$system" "$repo"
    else
        _sync "$repo" "$system"
    fi
}

sync "$NVIM_DIR"      "$NVIM_REPO"
sync "$ALACRITTY_DIR" "$ALACRITTY_REPO"
sync "$GHOSTTY_DIR"   "$GHOSTTY_REPO"
sync "$YAZI_DIR"      "$YAZI_REPO"

sync "$VIMRC_FILE"     "$VIMRC_REPO"
sync "$GITCONFIG_FILE" "$GITCONFIG_REPO"
sync "$ZSHRC_FILE"     "$ZSHRC_REPO"
sync "$BASHRC_FILE"    "$BASHRC_REPO"
sync "$TMUX_FILE"      "$TMUX_REPO"

rm -f ./config/nvim/nvim-pack-lock.json
